# {{ .SudoersFilename }} — generated by nginx-ui host-setup.
# Install with: sudo visudo -f {{ .SudoersFilename }}
{{ .HostUser }} ALL=(root) NOPASSWD: \
    {{ .SystemctlPath }} reload {{ .SystemdUnit }}, \
    {{ .SystemctlPath }} restart {{ .SystemdUnit }}, \
    {{ .NginxSbinPath }} -t, \
    {{ .NginxSbinPath }} -T
Defaults!{{ .SystemctlPath }},{{ .NginxSbinPath }} env_keep += "TZ LANG LC_ALL"
