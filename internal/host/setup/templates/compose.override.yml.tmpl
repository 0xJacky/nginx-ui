# docker-compose.override.yml — drop into the same dir as your main compose file.
services:
  nginx-ui:
{{- if .UseHostGateway }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{{- end }}
    volumes:
      - {{ .HostConfigDir }}:{{ .ContainerConfigDir }}
      - {{ .HostLogDir }}:{{ .ContainerLogDir }}:ro
      - /var/run:/var/run:ro
{{- if not .UseGeneratedKey }}
      - {{ .HostKeyPath }}:{{ .ContainerKeyPath }}:ro
      - {{ .HostKnownHostsPath }}:{{ .ContainerKnownHostsPath }}:ro
{{- end }}
    environment:
      NGINX_UI_NGINX_HOST_MODE: ssh
      NGINX_UI_NGINX_HOST_ADDRESS: {{ .HostAddress }}
      NGINX_UI_NGINX_HOST_USER: {{ .HostUser }}
      NGINX_UI_NGINX_HOST_PRIVATE_KEY_PATH: {{ .ContainerKeyPath }}
      NGINX_UI_NGINX_HOST_KNOWN_HOSTS_PATH: {{ .ContainerKnownHostsPath }}
      NGINX_UI_NGINX_HOST_SYSTEMD_UNIT_NAME: {{ .SystemdUnit }}
      NGINX_UI_NGINX_HOST_SYSTEMCTL_PATH: {{ .SystemctlPath }}
      NGINX_UI_NGINX_HOST_CONFIG_DIR: {{ .HostConfigDir }}
      NGINX_UI_NGINX_HOST_LOG_DIR: {{ .HostLogDir }}
      NGINX_UI_DISABLE_BUNDLED_NGINX: "true"
